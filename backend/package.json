{
  "name": "aethermint-education-backend",
  "version": "1.0.0",
  "description": "Backend API for AetherMint decentralized education platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "build:babel": "babel src -d dist --extensions \".ts,.js\"",
    "lint": "eslint src/ --ext .ts,.js",
    "lint:fix": "eslint src/ --ext .ts,.js --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:verbose": "jest --verbose",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:api": "jest --testPathPattern=routes",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "test:federated": "jest --testPathPattern=federatedLearning",
    "test:all": "npm run test:ci && npm run test:api && npm run test:federated",
    "typecheck": "tsc --noEmit",
    "python:install": "pip install -r requirements.txt",
    "python:setup": "python -m spacy download en_core_web_sm"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.5.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "brain.js": "^2.0.0-beta.24",
    "compromise": "^14.10.0",
    "cors": "^2.8.5",
    "d3": "^7.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.7.0",
    "graphlib": "^2.1.8",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "ipfs-http-client": "^60.0.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.13",
    "ml-kmeans": "^6.0.0",
    "ml-matrix": "^6.10.4",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^6.5.0",
    "neo4j-driver": "^5.11.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "node-nlp": "^4.27.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "redis": "^4.6.8",
    "sentiment": "^5.0.2",
    "socket.io": "^4.7.2",
    "twilio": "^5.13.1",
    "aws-sdk": "^2.1668.0",
    "ffmpeg-static": "^5.1.0",
    "sharp": "^0.32.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.15",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.22.15",
    "@elastic/elasticsearch": "^9.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.13",
    "@types/d3": "^7.4.0",
    "@types/express": "^4.17.17",
    "@types/express-validator": "^3.0.0",
    "@types/fluent-ffmpeg": "^2.1.21",
    "@types/geoip-lite": "^1.4.2",
    "@types/graphlib": "^2.1.12",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/natural": "^6.0.1",
    "@types/node": "^20.5.1",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.4",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "jest-environment-node": "^29.6.2",
    "mongodb-memory-server": "^8.15.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "education",
    "api",
    "node.js",
    "express",
    "postgresql"
  ],
  "author": "jobbykings",
  "license": "MIT"
}
