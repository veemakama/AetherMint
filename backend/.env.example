# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
IPFS_API_PATH=/api/v0
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# IPFS Upload Configuration
IPFS_MAX_FILE_SIZE=104857600
IPFS_CHUNK_SIZE=1048576
IPFS_AUTO_PIN=true
IPFS_PIN_TIMEOUT=30000

# IPFS Caching
IPFS_ENABLE_CACHE=true
IPFS_CACHE_TIMEOUT=3600000

# IPFS Retry Configuration
IPFS_MAX_RETRIES=3
IPFS_RETRY_DELAY=1000

# IPFS Authentication (optional)
IPFS_AUTH_ENABLED=false
IPFS_AUTH_USERNAME=
IPFS_AUTH_PASSWORD=
IPFS_AUTH_TOKEN=

# IPFS Metadata Configuration
IPFS_INCLUDE_TIMESTAMP=true
IPFS_INCLUDE_UPLOADER=true
IPFS_INCLUDE_CONTENT_TYPE=true
IPFS_INCLUDE_FILE_SIZE=true

# JWT Configuration (for IPFS authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/aethermint-education
# Or for PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/aethermint-education

# Redis Configuration (for Transaction Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Swarm Learning Configuration
SWARM_MIN_AGENTS=3
SWARM_MAX_AGENTS=1000
SWARM_COMMUNICATION_RADIUS=5
SWARM_LEARNING_RATE=0.01
SWARM_EXPLORATION_RATE=0.1
SWARM_CONVERGENCE_THRESHOLD=0.001
SWARM_MAX_ITERATIONS=1000
SWARM_TIMEOUT_MS=300000

# Swarm Network Configuration
SWARM_INITIAL_CONNECTIONS=3
SWARM_MAX_CONNECTIONS=10
SWARM_MIN_CONNECTIONS=2
SWARM_REORGANIZATION_INTERVAL=30000
SWARM_TOPOLOGY_TYPE=small_world

# Swarm Analytics Configuration
SWARM_METRICS_RETENTION_PERIOD=86400000
SWARM_AGGREGATION_INTERVAL=60000
SWARM_LOW_PERFORMANCE_THRESHOLD=0.5
SWARM_HIGH_LATENCY_THRESHOLD=5000
SWARM_LOW_CONVERGENCE_THRESHOLD=0.3
SWARM_NETWORK_FRAGMENTATION_THRESHOLD=0.7

# Swarm Communication Configuration
SWARM_ENCRYPTION_ENABLED=true
SWARM_AUTHENTICATION_ENABLED=true
SWARM_MAX_MESSAGE_SIZE=1048576
SWARM_MESSAGE_TIMEOUT=30000
SWARM_RETRY_ATTEMPTS=3
SWARM_RETRY_DELAY=1000

# Swarm Behavior Detection Configuration
SWARM_DETECTION_WINDOW=60000
SWARM_MIN_PATTERN_OCCURRENCES=3
SWARM_CONFIDENCE_THRESHOLD=0.7
SWARM_ANALYSIS_INTERVAL=5000

# Swarm Collective Intelligence Configuration
SWARM_AGGREGATION_METHOD=weighted_average
SWARM_CONSENSUS_THRESHOLD=0.67
SWARM_DIVERSITY_BONUS=0.1
SWARM_MEMORY_DECAY=0.95

# Logging Configuration
LOG_LEVEL=debug

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_FEE=100
STELLAR_TIMEOUT=30000
STELLAR_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=debug

# Transaction Queue Configuration
TRANSACTION_QUEUE_BATCH_SIZE=10
TRANSACTION_QUEUE_PROCESSING_DELAY=2000
TRANSACTION_QUEUE_MAX_CONCURRENT=5
TRANSACTION_CONFIRMATION_TIMEOUT=300000
