# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
IPFS_API_PATH=/api/v0
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# IPFS Upload Configuration
IPFS_MAX_FILE_SIZE=104857600
IPFS_CHUNK_SIZE=1048576
IPFS_AUTO_PIN=true
IPFS_PIN_TIMEOUT=30000

# IPFS Caching
IPFS_ENABLE_CACHE=true
IPFS_CACHE_TIMEOUT=3600000

# IPFS Retry Configuration
IPFS_MAX_RETRIES=3
IPFS_RETRY_DELAY=1000

# IPFS Authentication (optional)
IPFS_AUTH_ENABLED=false
IPFS_AUTH_USERNAME=
IPFS_AUTH_PASSWORD=
IPFS_AUTH_TOKEN=

# IPFS Metadata Configuration
IPFS_INCLUDE_TIMESTAMP=true
IPFS_INCLUDE_UPLOADER=true
IPFS_INCLUDE_CONTENT_TYPE=true
IPFS_INCLUDE_FILE_SIZE=true

# JWT Configuration (for IPFS authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/aethermint-education
# Or for PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/aethermint-education

# Redis Configuration (for Transaction Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_FEE=100
STELLAR_TIMEOUT=30000
STELLAR_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=debug

# Transaction Queue Configuration
TRANSACTION_QUEUE_BATCH_SIZE=10
TRANSACTION_QUEUE_PROCESSING_DELAY=2000
TRANSACTION_QUEUE_MAX_CONCURRENT=5
TRANSACTION_CONFIRMATION_TIMEOUT=300000
