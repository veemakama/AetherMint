{
  "name": "aethermint-education-frontend",
  "version": "1.0.0",
  "description": "Frontend for AetherMint decentralized education platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "NEXT_PUBLIC_STELLAR_RECEIVER_ADDRESS=GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWNA jest",
    "test:watch": "NEXT_PUBLIC_STELLAR_RECEIVER_ADDRESS=GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWNA jest --watch",
    "test:coverage": "NEXT_PUBLIC_STELLAR_RECEIVER_ADDRESS=GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWNA jest --coverage",
    "test:ci": "NEXT_PUBLIC_STELLAR_RECEIVER_ADDRESS=GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWNA jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=json,html,junit",
    "test:e2e:install": "playwright install --with-deps",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "husky install",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "performance-test": "npm run build && npm run lighthouse"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
