# =============================================================================
# AetherMint Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# All NEXT_PUBLIC_* variables are exposed to the browser.
# =============================================================================

# ---- REQUIRED ----------------------------------------------------------------

# Stellar public key that receives course enrollment payments.
# Must be a valid 56-character Stellar address starting with "G".
# Example: GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWNA
NEXT_PUBLIC_STELLAR_RECEIVER_ADDRESS=

# ---- OPTIONAL ----------------------------------------------------------------

# Base URL of the AetherMint backend API server.
# Used for collaboration rooms and general API calls.
# Default: http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# WebSocket server URL for real-time features.
# Default: ws://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# API URL for the consciousness/general services.
# Default: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# API base URL used by the discovery/course service.
# Default: http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# VAPID public key for Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Socket.IO server URL for gamification/leaderboard real-time updates.
# Default: http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
