{
  "name": "aethermint-education",
  "version": "0.1.0",
  "description": "Decentralized learning and credential verification platform powered by Stellar blockchain",
  "main": "index.js",
  "scripts": {
    "install:all": "pnpm install && cd contracts && cargo build",
    "build": "pnpm run build:contracts && pnpm run build:backend && pnpm run build:frontend",
    "build:contracts": "cd contracts && cargo build --release",
    "build:backend": "cd backend && pnpm run build",
    "build:frontend": "cd frontend && pnpm run build",
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "cd backend && pnpm run dev",
    "dev:frontend": "cd frontend && pnpm run dev"
  },
  "dependencies": {
    "aws-sdk": "^2.1450.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "ffmpeg-static": "^5.2.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "recharts": "^3.7.0",
    "sharp": "^0.32.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "concurrently": "^8.2.0",
    "jest": "^29.6.4",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "education",
    "credentials",
    "soroban",
    "web3",
    "decentralized",
    "learning",
    "certificates"
  ],
  "author": "jobbykings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akordavid373/aethermint-education.git"
  },
  "bugs": {
    "url": "https://github.com/akordavid373/aethermint-education/issues"
  },
  "homepage": "https://github.com/akordavid373/aethermint-education#readme",
  "workspaces": [
    "contracts",
    "backend",
    "frontend"
  ]
}